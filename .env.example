DATABASE_URL="postgresql://localhost:5432/skills_directory"
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# OIDC/SSO (optional — enables SSO login button)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Redis (optional — enables distributed rate limiting for multi-pod deployments)
REDIS_URL=

# Database connection pool (per pod, default: 10)
DB_POOL_MAX=10

# Server port (default: 3000, may be set by container orchestrator)
PORT=3000
