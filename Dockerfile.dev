FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json ./
RUN npm ci

# Copy prisma schema for generate
COPY prisma ./prisma
COPY prisma.config.ts ./

# Generate Prisma client
RUN npx prisma generate

# Source code is volume-mounted at runtime for hot reload
# Copy it here as fallback
COPY . .

EXPOSE 3000

# Run migrations, seed, then start dev server
CMD sh -c "npx prisma migrate deploy && npm run seed 2>/dev/null; npm run dev"
